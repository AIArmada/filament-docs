{
  "name": "aiarmada/filament-docs",
  "description": "A comprehensive Filament admin interface for managing documents created by the AIArmada Docs package",
  "license": "MIT",
  "homepage": "https://github.com/aiarmada/commerce",
  "support": {
    "issues": "https://github.com/aiarmada/commerce/issues",
    "source": "https://github.com/aiarmada/commerce"
  },
  "require": {
    "aiarmada/docs": "self.version",
    "filament/filament": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "AIArmada\\FilamentDocs\\": "src/",
      "AIArmada\\FilamentDocs\\Database\\Factories\\": "database/factories/",
      "AIArmada\\FilamentDocs\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AIArmada\\FilamentDocs\\FilamentDocsServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
